{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "typeRoots": [
      "./server/node_modules/@types",
      "./node_modules/@types"
    ],
    "paths": {
      "*": ["server/node_modules/*"]
    }
  },
  "include": ["api/**/*", "server/src/**/*"]
}
